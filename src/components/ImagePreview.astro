---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: string | ImageMetadata;
  alt: string;
  class?: string;
  [key: string]: any;
}

const { src, alt, class: className, ...props } = Astro.props;

// For remote images, don't infer size to avoid fetch failures
const isRemoteImage = typeof src === "string" && src.startsWith("http");
---

<div class="image-preview-container">
  {
    isRemoteImage ? (
      <img
        src={src as string}
        alt={alt}
        class={`preview-image cursor-pointer ${className || ""}`}
        loading="eager"
        {...props}
      />
    ) : (
      // @ts-expect-error
      <Image
        src={src}
        alt={alt}
        class={`preview-image cursor-pointer ${className || ""}`}
        loading="eager"
        {...props}
        inferSize={true}
      />
    )
  }
</div>
