---
type Props = {
  repoURL: string;
  starCount?: number;
};

const { repoURL } = Astro.props;

// Extract owner and repo from GitHub URL
const githubUrlPattern = /^https:\/\/github\.com\/([^/]+)\/([^/]+)/;
const match = repoURL.match(githubUrlPattern);

const githubInfo = match ? { owner: match[1], repo: match[2] } : null;
---

{
  githubInfo && (
    <span
      class="inline-flex items-center gap-1 text-sm dark:text-orange-500 github-stars"
      data-owner={githubInfo.owner}
      data-repo={githubInfo.repo}
    >
      <svg class="w-3 h-3 fill-current" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" />
      </svg>
      <span class="star-count dark:text-gray-400 flex items-center gap-1">
        <span class="star-spinner w-2 h-2 border border-current border-t-transparent rounded-full animate-spin hidden" />
        <span class="star-value">-</span>
      </span>
    </span>
  )
}

<style>
  .star-spinner {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script>
  // Client-side fetching of GitHub star counts
  async function fetchGitHubStars() {
    const starElements: NodeListOf<HTMLElement> =
      document.querySelectorAll(".github-stars");

    for (const element of starElements) {
      const owner = element.dataset.owner;
      const repo = element.dataset.repo;
      const spinnerElement = element.querySelector(".star-spinner");
      const valueElement = element.querySelector(".star-value");

      if (!spinnerElement || !valueElement) continue;

      // Skip if already fetched
      if (valueElement.textContent !== "-") continue;

      // Show spinner, hide value
      spinnerElement.classList.remove("hidden");
      valueElement.classList.add("hidden");

      try {
        // Add a small delay to avoid rate limiting
        await new Promise((resolve) => setTimeout(resolve, 100));

        const response = await fetch(
          `https://api.github.com/repos/${owner}/${repo}`,
          {
            headers: {
              Accept: "application/vnd.github.v3+json",
            },
          }
        );

        if (response.ok) {
          const data = await response.json();
          valueElement.textContent =
            data.stargazers_count?.toLocaleString() || "0";
        } else {
          valueElement.textContent = "?";
        }
      } catch (error) {
        console.warn(`Failed to fetch star count for ${owner}/${repo}:`, error);
        valueElement.textContent = "?";
      } finally {
        // Hide spinner, show value
        spinnerElement.classList.add("hidden");
        valueElement.classList.remove("hidden");
      }
    }
  }

  // Run on initial page load
  document.addEventListener("DOMContentLoaded", fetchGitHubStars);

  // Run on Astro page transitions (client-side navigation)
  document.addEventListener("astro:page-load", fetchGitHubStars);
</script>
